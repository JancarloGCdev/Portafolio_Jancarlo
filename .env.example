# Siguientes variables son necesarias sólo si usas el panel /admin CMS (no requeridas sólo para leer datos estáticos de lib/).
NEXT_PUBLIC_SITE_URL=

# Secreto HMAC JWT (≥ 32 caracteres; genera algo aleatorio y guárdalo fuera del repo)
CMS_ADMIN_SECRET=pon-aqui-un-string-aleatorio-de-al-menos-32-caracteres

# bcrypt: escapa CADA $ con \ (si no, Next lee $2b / $12 como variables y el hash queda vacío)
#   node -e "import('bcryptjs').then(m => m.hash('tu-password', 12).then(console.log))"
CMS_ADMIN_PASSWORD_HASH=\$2b\$12\$REEMPLAZA_CON_TU_HASH_BCRYPT_COMPLETO
